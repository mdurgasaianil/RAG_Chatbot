    "def chunk_document(raw_text: str) -> list[Document]:\n",
    "    \"\"\"\n",
    "    Splits raw text into overlapping chunks\n",
    "    Returns list of LangChain Document objects\n",
    "    \"\"\"\n",
    "    splitter = RecursiveCharacterTextSplitter(\n",
    "        chunk_size=500,\n",
    "        chunk_overlap=50,\n",
    "        separators=[\"\\n\\n\", \"\\n\", \".\", \" \"]\n",
    "    )\n",
    "    \n",
    "    chunks = splitter.split_text(raw_text)\n",
    "    \n",
    "    # Wrap each chunk in a LangChain Document object\n",
    "    documents = [Document(page_content=chunk) for chunk in chunks]\n",
    "    \n",
    "    print(f\"Total chunks created: {len(documents)}\")\n",
    "    print(f\"\\nChunk 1 preview:\\n{documents[0].page_content}\")\n",
    "    print(f\"\\nChunk 2 preview:\\n{documents[1].page_content}\")\n",
    "    \n",
    "    return documents\n",
    "\n",
    "\n",
    "documents = chunk_document(raw_text)"
   ]
