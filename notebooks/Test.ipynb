    "import fitz  # PyMuPDF\n",
    "from docx import Document as DocxDocument\n",
    "\n",
    "def load_document(file_path: str) -> str:\n",
    "    \"\"\"\n",
    "    Loads text from PDF, DOCX, or TXT file\n",
    "    Returns raw text as a single string\n",
    "    \"\"\"\n",
    "    ext = file_path.split(\".\")[-1].lower()\n",
    "    \n",
    "    if ext == \"pdf\":\n",
    "        doc = fitz.open(file_path)\n",
    "        text = \"\"\n",
    "        for page in doc:\n",
    "            text += page.get_text()\n",
    "        return text\n",
    "    \n",
    "    elif ext == \"docx\":\n",
    "        doc = DocxDocument(file_path)\n",
    "        text = \"\"\n",
    "        for para in doc.paragraphs:\n",
    "            text += para.text + \"\\n\"\n",
    "        return text\n",
    "    \n",
    "    elif ext == \"txt\":\n",
    "        with open(file_path, \"r\", encoding=\"utf-8\") as f:\n",
    "            return f.read()\n",
    "    \n",
    "    else:\n",
    "        raise ValueError(f\"Unsupported file type: {ext}\")\n",
    "\n",
    "\n",
    "# Test it — upload any PDF/DOCX/TXT to your project folder and try\n",
    "file_path = \"/Users/anilmutyala/Documents/Rag_ChatBot/Appointment Letter_Durga Sai Anil Mutyala.pdf\"  # change this to your file\n",
    "raw_text = load_document(file_path)\n",
    "\n",
    "print(f\"Document loaded ✓\")\n",
    "print(f\"Total characters: {len(raw_text)}\")\n",
    "print(f\"Preview:\\n{raw_text[:300]}\")"
